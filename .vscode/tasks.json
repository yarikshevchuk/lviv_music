{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "Build All Files",
      "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "-o",
        "${fileDirname}\\main.exe",
        "$(Get-Item -Path \"${fileDirname}\\*.cpp\" | ForEach-Object { $_.FullName })"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ],
}
